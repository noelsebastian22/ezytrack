---
import { siteContent } from "@/data/siteContent";

const { title, paragraphs, ctaText, imageSrc, imageAlt } = siteContent.benefitsSplit;
const ctaHref = `mailto:${siteContent.global.contactEmail}?subject=Quote%20enquiry`;
---

<section class="w-full bg-background py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="order-2 lg:order-1">
        <h2 class="text-3xl font-bold text-text-primary md:text-4xl">
          {title}
        </h2>
        <div class="mt-6 space-y-4">
          {
            paragraphs.map((paragraph) => (
              <p class="text-base leading-relaxed text-text-secondary">
                {paragraph}
              </p>
            ))
          }
        </div>
        <a
          href={ctaHref}
          class="mt-8 inline-flex rounded-full bg-brand px-8 py-3.5 text-base font-semibold text-brand-foreground transition-colors hover:bg-brand-hover"
        >
          {ctaText}
        </a>
      </div>

      <div class="order-1 lg:order-2">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-float relative">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="h-full w-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.hidden=true;this.nextElementSibling.hidden=false"
          />
          <div hidden class="absolute inset-0 flex items-center justify-center bg-surface-muted">
            <span class="text-sm text-text-muted">Image unavailable</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

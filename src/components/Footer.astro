---
import { siteContent } from "@/data/siteContent";

const { companyName, companyGroup, contactEmail, contactPhone } = siteContent.global;
const { description, columns, copyright } = siteContent.footer;
---

<footer class="w-full bg-surface-dark text-text-inverse">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-6">
      <div class="lg:col-span-2">
        <h3 class="text-2xl font-bold text-text-inverse">{companyName}</h3>
        <p class="mt-1 text-sm text-text-inverse-muted">{companyGroup}</p>
        <p class="mt-4 max-w-sm text-base leading-relaxed text-text-inverse-muted">
          {description}
        </p>
      </div>

      {
        columns.map((column) => (
          <div>
            <h4 class="text-base font-semibold text-text-inverse">{column.title}</h4>
            <ul class="mt-4 flex flex-col gap-3">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.href.startsWith("http") ? "_blank" : undefined}
                    rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                    class="text-base text-text-inverse-muted transition-colors hover:text-text-inverse"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div>
        <h4 class="text-base font-semibold text-text-inverse">Contact</h4>
        <ul class="mt-4 flex flex-col gap-3">
          <li>
            <a
              href={`mailto:${contactEmail}`}
              class="text-base text-text-inverse-muted transition-colors hover:text-text-inverse"
            >
              {contactEmail}
            </a>
          </li>
          <li>
            <a
              href={`tel:${contactPhone.replace(/\s/g, "")}`}
              class="text-base text-text-inverse-muted transition-colors hover:text-text-inverse"
            >
              {contactPhone}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-border-dark pt-8">
      <p class="text-sm text-text-inverse-muted">{copyright}</p>
    </div>
  </div>
</footer>

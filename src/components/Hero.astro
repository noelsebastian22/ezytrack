---
import { siteContent } from "@/data/siteContent";

const { headline, subheadline, primaryCta, backgroundImage } = siteContent.hero;
const ctaHref = `mailto:${siteContent.global.contactEmail}?subject=Quote%20enquiry`;
---

<section
  class="relative flex min-h-[calc(100vh-4.5rem)] items-center justify-center overflow-hidden"
  aria-label="Hero"
>
  <img
    src={backgroundImage}
    alt=""
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    decoding="async"
    onerror="this.hidden=true"
  />
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 py-24 text-center md:px-8">
    <h1
      class="animate-fade-in-up text-4xl font-bold leading-tight text-text-inverse md:text-5xl lg:text-6xl"
    >
      {headline}
    </h1>
    <p
      class="animate-fade-in-up mt-6 text-lg text-text-inverse-muted md:text-xl"
      style="animation-delay: 150ms;"
    >
      {subheadline}
    </p>
    <div
      class="animate-fade-in-up mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
      style="animation-delay: 300ms;"
    >
      <a
        href={ctaHref}
        class="rounded-full bg-brand px-8 py-3.5 text-base font-semibold text-brand-foreground transition-colors hover:bg-brand-hover"
      >
        {primaryCta}
      </a>
    </div>
  </div>
</section>

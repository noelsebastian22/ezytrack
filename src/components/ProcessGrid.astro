---
import { siteContent } from "@/data/siteContent";
import { Check } from "lucide-react";

const { title, steps } = siteContent.process;
---

<section class="w-full bg-background py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <h2 class="mx-auto max-w-3xl text-center text-3xl font-bold text-text-primary md:text-4xl">
      {title}
    </h2>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        steps.map((step, index) => (
          <div class="group overflow-hidden rounded-2xl bg-surface shadow-sm transition-transform duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={step.imageSrc}
                alt={step.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-6">
              <div class="flex items-start gap-3">
                <div class="mt-1 flex-shrink-0 rounded-full bg-success-background p-1">
                  <Check className="size-4 text-success" />
                </div>
                <div>
                  <span class="text-sm font-semibold text-text-muted">
                    Step {index + 1}
                  </span>
                  <h3 class="text-xl font-semibold text-text-primary">
                    {step.title}
                  </h3>
                </div>
              </div>
              <p class="mt-3 text-base leading-relaxed text-text-secondary">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

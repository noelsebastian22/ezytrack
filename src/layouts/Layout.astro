---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@/styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ezytrack - GPS Fleet Tracking Australia",
  description = "Market-leading GPS fleet tracking, asset tracking, and dashcam solutions for Australian businesses.",
} = Astro.props;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="font-sans text-text-primary antialiased">
    <slot />
  </body>
</html>
